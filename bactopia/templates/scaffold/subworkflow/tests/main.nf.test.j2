nextflow_workflow {
    name "Test {{ process_name }} Subworkflow"
    script "../main.nf"
    workflow "{{ process_name }}"
    tag "subworkflows"
    tag "{{ tool }}"

    test("{{ tool }} - subworkflow - {{ test_sample_id }}") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "{{ test_sample_id }}"],
{% if input_type == 'assembly' %}
                        fna: file("${params.test_data_dir}/{{ test_data_path }}")
{% endif %}
                    )
                )
{% if has_database %}
                input[1] = file("${params.test_data_dir}/{{ db_test_path }}")
{% endif %}
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
{% if has_aggregation %}
            def run = workflow.out.run_outputs[0]
{% endif %}
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
{% for output in outputs %}
                    sample.{{ output.name }},
{% endfor %}
                    sample.versions,
{% if has_aggregation %}
                    run.meta,
                    run.versions
{% endif %}
                ).match() },
                { assert sample.results != null },
{% if has_csvtk %}
                { assert run.csv != null },
                { assert run.results != null }
{% elif has_summary %}
                { assert run.results != null }
{% endif %}
            )
        }
    }
}
